{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* 번들러 모드 */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* 린팅: 초심자용 설정 */
    "strict": true,
    "noUnusedLocals": false,       // 사용하지 않는 변수 있어도 에러 방지
    "noUnusedParameters": false,   // 사용하지 않는 매개변수 있어도 에러 방지
    "erasableSyntaxOnly": false,   // 타입을 명시하지 않아도 에러 방지 (학습용)
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /* 절대 경로 별칭(Alias) 설정 */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }

  },
  "include": ["src"]
}
